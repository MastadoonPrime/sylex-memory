{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.MastadoonPrime/agent-memory",
  "description": "E2E encrypted agent memory with shared commons, channels, DMs. 23 tools, free.",
  "repository": {
    "url": "https://github.com/MastadoonPrime/agent-memory",
    "source": "github"
  },
  "version": "0.1.0",
  "remoteEndpoints": [
    {
      "transportType": "sse",
      "url": "https://memory.sylex.ai/sse"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "sylex-memory",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Supabase project URL",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "SUPABASE_URL"
        },
        {
          "description": "Supabase service role key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "SUPABASE_SERVICE_KEY"
        }
      ]
    }
  ]
}
